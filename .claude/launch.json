{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "docker-dev",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "port": 8000
    },
    {
      "name": "uvicorn-local",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["backend.app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    }
  ]
}
